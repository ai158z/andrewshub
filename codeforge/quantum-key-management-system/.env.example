# Quantum Key Management System - Environment Configuration Template

# Quantum Backend Configuration
QUANTUM_BACKEND=qiskit
QUANTUM_SIMULATOR_BACKEND=qiskit.BasicAer
QUANTUM_REAL_BACKEND=ibmq_qasm_simulator

# Logging Configuration
LOG_LEVEL=INFO
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s
LOG_FILE=logs/qkms.log

# API Configuration
API_HOST=localhost
API_PORT=8080
API_DEBUG=False

# Security Configuration
SECRET_KEY=your-secret-key-here
JWT_SECRET_KEY=your-jwt-secret-here
JWT_ALGORITHM=HS256
JWT_EXPIRATION_DELTA=30

# Database Configuration (if needed in future)
DATABASE_URL=sqlite:///qkms.db

# Key Storage Configuration
KEY_STORAGE_PATH=/var/lib/qkms/keys
KEY_ENCRYPTION_KEY=your-key-encryption-key-here

# Authentication Configuration
AUTH_ENABLED=True
CERTIFICATE_AUTHORITY_URL=https://ca.example.com
CERTIFICATE_VALIDITY_DAYS=365

# Network Configuration
NETWORK_TIMEOUT=30
MAX_CONNECTIONS=100

# Performance Configuration
PERFORMANCE_MONITORING=True
LATENCY_THRESHOLD_MS=100

# Fallback Configuration
FALLBACK_ENABLED=True
FALLBACK_ENCRYPTION_ALGORITHM=AES256
FALLBACK_KEY_SIZE=256

# Encoding Configuration
SYMBOLIC_ENCODING_ENABLED=True
CODONIC_LAYER_ENABLED=True

# Monitoring Configuration
MONITORING_ENABLED=True
METRICS_COLLECTION_INTERVAL=60
HEALTH_CHECK_ENDPOINT=/health

# Certificate Configuration
CERTIFICATE_LIFETIME_HOURS=8760
RENEWAL_THRESHOLD_DAYS=30

# Quantum Channel Configuration
QUANTUM_CHANNEL_FIDELITY_THRESHOLD=0.95
CHANNEL_ERROR_CORRECTION=True

# Key Distribution Configuration
KEY_DISTRIBUTION_PROTOCOL=BB84
KEY_SIZE_BITS=2048

# Edge Node Authentication Configuration
EDGE_NODE_AUTH_ENABLED=True
EDGE_NODE_CERTIFICATE_LIFETIME_HOURS=720

# Backup Channel Configuration
BACKUP_CHANNEL_ENABLED=True
BACKUP_CHANNEL_TYPE=classical

# Latency Configuration
LATENCY_WARNING_THRESHOLD_MS=200
LATENCY_CRITICAL_THRESHOLD_MS=500

# System Configuration
DEBUG=False
TESTING=False
THREADS_PER_CORE=4
MAX_WORKERS=10

# External Service Configuration
QISKIT_IBM_CHANNEL=ibm-q-channel
QISKIT_IBM_TOKEN=your-ibm-token-here
QISKIT_IBM_HUB=ibm-q
QISKIT_IBM_GROUP=open
QISKIT_IBM_PROJECT=main

# Resource Limits
MAX_KEY_SIZE=4096
CONCURRENT_CONNECTIONS_LIMIT=1000
MEMORY_LIMIT_MB=2048

# Compliance Configuration
COMPLIANCE_MODE=strict
AUDIT_LOGGING=True

# Notification Configuration
ALERT_EMAIL=admin@qkms.local
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/your/slack/webhook

# Backup Configuration
BACKUP_ENABLED=True
BACKUP_INTERVAL_HOURS=24
BACKUP_RETENTION_DAYS=30

# Cache Configuration
CACHE_ENABLED=True
CACHE_TTL_SECONDS=300
CACHE_SIZE_LIMIT=1000

# Retry Configuration
MAX_RETRY_ATTEMPTS=3
RETRY_BACKOFF_SECONDS=5

# Health Check Configuration
HEALTH_CHECK_INTERVAL_SECONDS=30
HEALTH_CHECK_TIMEOUT_SECONDS=10
LIVENESS_PROBE_PATH=/health/liveness
READINESS_PROBE_PATH=/health/readiness