# Quantum Android Edge Framework - Environment Variables Example
# This file contains example values. Please copy to .env and update with actual values.

# Backend Service URL
QUANTUM_BACKEND_URL=http://localhost:8000

# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/quantum_android_db

# Redis Configuration
REDIS_URL=redis://localhost:6379/0

# RabbitMQ Configuration
RABBITMQ_URL=amqp://guest:guest@localhost:5672

# Security Settings
SECRET_KEY=your-super-secret-key-here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# PostgreSQL Database Settings
POSTGRES_USER=quantum_user
POSTGRES_PASSWORD=quantum_password
POSTGRES_DB=quantum_android_db
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# API Keys and Tokens
QUANTUM_ENCRYPTION_KEY=quantum_encryption_secret_key
IIT_CONTINUITY_TOKEN=iit_continuity_validation_token

# Node Configuration
NODE_ID=node_001
NODE_TYPE=quantum_processing_unit

# Simulation Settings
SIMULATION_SCENARIO=default_embodiment_scenario
EMERGENT_BEHAVIOR_THRESHOLD=0.75

# Server Configuration
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
LOG_LEVEL=info
DEBUG=false

# Redis Settings
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# PostgreSQL SSL (if needed)
POSTGRES_SSL_MODE=require
POSTGRES_SSL_CERT_FILE=/path/to/client-cert.pem
POSTGRES_SSL_KEY_FILE=/path/to/client-key.pem
POSTGRES_SSL_ROOT_CERT_FILE=/path/to/server-ca.pem

# Security Headers
SECURITY_API_KEY=your-security-api-key
SECURITY_API_SECRET=your-security-api-secret
CORS_ORIGINS=["http://localhost:3000","https://yourdomain.com"]
ENCRYPTION_SALT=quantum_salt_value
HASHING_ALGORITHM=cryptography_sha256
AUTH_TOKEN_EXPIRY=86400

# External Service URLs
QUANTUM_API_BASE_URL=https://api.quantumframework.ai/v1
EXTERNAL_DATA_SYNC_URL=https://sync.quantumframework.ai/data
LIVE_DATA_FEED_URL=wss://feed.quantumframework.ai/live

# Feature Flags
FEATURE_FLAG_ENABLE_SIMULATION=true
FEATURE_FLAG_ENABLE_ENCRYPTION=true
FEATURE_FLAG_ENABLE_IIT_PROCESSING=true
FEATURE_FLAG_ENABLE_CODONIC_LAYER=true
FEATURE_FLAG_ENABLE_QUANTUM_NODES=true