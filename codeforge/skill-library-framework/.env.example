# Application Settings
APP_ENV=development
DEBUG=False
LOG_LEVEL=INFO

# Security
SECRET_KEY=your-secret-key-here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Database Configuration
DATABASE_URL=sqlite:///./skill_library.db
POSTGRES_USER=skilluser
POSTGRES_PASSWORD=skillpassword
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=skilldb

# Redis Configuration
REDIS_URL=redis://localhost:6379/0

# API Settings
API_HOST=0.0.0.0
API_PORT=8000

# Model Settings
MODEL_PATH=./models
EMBEDDING_DIM=768

# External Service URLs
PYTORCH_MODEL_URL=https://huggingface.co/models/
TRANSFORMERS_CACHE=/app/cache/transformers

# Performance Settings
MAX_CONNECTIONS=10
POOL_RECYCLE=3600

# Feature Flags
ENABLE_CURIOSITY_BUDGET=True
ENABLE_PREDICTIVE_SCORING=True
ENABLE_TASK_SCORING=True

# Vector DB Settings
VECTOR_DB_PATH=/tmp/vectordb
VECTOR_DB_DIMENSIONS=768
FAISS_INDEX_TYPE=Flat

# CORS Settings
CORS_ORIGINS=["*"]
CORS_CREDENTIALS=True
CORS_METHODS=["*"]
CORS_HEADERS=["*"]