# Environment Variables for Staking Reward Calculator CLI

# Blockchain Network Configuration
BLOCKCHAIN_NETWORK=ethereum
BLOCKCHAIN_NODE_URL=https://mainnet.infura.io/v3/YOUR_INFURA_PROJECT_ID
BLOCKCHAIN_API_KEY=your_blockchain_api_key_here

# API Endpoints
API_BASE_URL=https://api.example.com/staking
COIN_GECKO_API_URL=https://api.coingecko.com/api/v3

# Cache Settings
CACHE_TTL=300
CACHE_ENABLED=true

# Application Settings
LOG_LEVEL=INFO
DEBUG_MODE=false

# External Service URLs
PRICE_API_URL=https://api.coingecko.com/api/v3/simple/price
VALIDATOR_API_URL=https://beaconcha.in/api/v1

# Security Settings
API_KEY=your_api_key_here
SECRET_KEY=your_secret_key_here

# Cache Configuration
CACHE_REDIS_URL=redis://localhost:6379/0

# Web3 Provider (for blockchain interactions)
WEB3_PROVIDER_URI=https://mainnet.infura.io/v3/YOUR_INFURA_PROJECT_ID

# Network and Performance
REQUEST_TIMEOUT=30
MAX_RETRIES=3
BACKOFF_FACTOR=0.3

# Data Fetching
DATA_FETCH_ENABLED=true
DATA_FETCH_INTERVAL=3600

# Output formatting
OUTPUT_CURRENCY=USD
OUTPUT_DECIMAL_PLACES=6

# Feature Flags
ENABLE_LOGGING=true
ENABLE_METRICS=false
ENABLE_CACHE=true

# Performance and Limits
RATE_LIMIT_REQUESTS_PER_MINUTE=60
MAX_CONCURRENT_REQUESTS=10

# Cache TTLs (in seconds)
PRICE_CACHE_TTL=600
REWARD_RATE_CACHE_TTL=300
VALIDATOR_CACHE_TTL=3600

# API Keys
COIN_GECKO_API_KEY=your_coingecko_api_key
INFURA_PROJECT_ID=your_infura_project_id
ETHERSCAN_API_KEY=your_etherscan_api_key

# Timeouts and Retries
HTTP_TIMEOUT=30
HTTP_RETRIES=3
HTTP_BACKOFF_FACTOR=1.0

# Cache Keys
CACHE_NAMESPACE=staking_calculator
CACHE_VERSION=v1

# Network Constants
DEFAULT_NETWORK=mainnet
DEFAULT_CURRENCY=ETH

# Minimum stake amount validation
MIN_STAKE_AMOUNT=0.1
MAX_STAKE_AMOUNT=1000000.0

# Report settings
REPORT_OUTPUT_FORMAT=json
REPORT_INCLUDE_CHARTS=false

# Debug settings
DEBUG_CALCULATION=false
DEBUG_TIMING=false

# Cache backend
CACHE_BACKEND=redis

# Cache expiration times
STAKE_DATA_CACHE_TTL=600
REWARD_RATE_CACHE_TTL=300
PRICE_DATA_CACHE_TTL=600
VALIDATOR_DATA_CACHE_TTL=3600

# Network specific settings
ETHEREUM_RPC_URL=https://mainnet.infura.io/v3/YOUR_INFURA_PROJECT_ID
POLYGON_RPC_URL=https://polygon-rpc.com/
BINANCE_RPC_URL=https://bsc-dataseed.binance.org/

# API configurations
API_RATE_LIMIT=100
API_TIMEOUT=30

# Cache configuration
CACHE_DIR=/tmp/staking_cache
CACHE_SIZE_LIMIT=100000000

# Network and API settings
DEFAULT_API_TIMEOUT=30
DEFAULT_RETRY_ATTEMPTS=3
DEFAULT_RETRY_DELAY=1.0

# Logging
LOG_FORMAT="%(asctime)s - %(name)s - %(levelname)s - %(message)s"
LOG_FILE_PATH=/var/log/staking-calculator.log

# Performance settings
MAX_WORKERS=4
BATCH_SIZE=100

# Data source configuration
DATA_SOURCE=blockchain
FALLBACK_DATA_SOURCE=api

# Cache warming
CACHE_WARMUP_ENABLED=false
CACHE_WARMUP_INTERVAL=300

# Alerting and monitoring
ALERT_THRESHOLD_HIGH_REWARD=0.2
ALERT_THRESHOLD_LOW_REWARD=0.05
MONITORING_ENABLED=false

# Output and reporting
REPORT_FORMAT=text
REPORT_INCLUDE_DETAILED_DATA=true

# Cache performance
CACHE_HIT_TTL=3600
CACHE_MISS_TTL=300
CACHE_ERROR_TTL=60

# Network configuration
NETWORK_TIMEOUT=30
NETWORK_RETRY_COUNT=3
NETWORK_RETRY_BACKOFF=1.5

# API rate limits
API_CALLS_PER_SECOND=10
API_BURST_LIMIT=100

# Cache settings
CACHE_COMPRESSION=false
CACHE_ENCRYPTION=false

# Data processing
DATA_PROCESSING_THREADS=4
DATA_PROCESSING_CHUNK_SIZE=1000

# Timezone settings
TIMEZONE=UTC
DATE_FORMAT=%Y-%m-%d
DATETIME_FORMAT=%Y-%m-%d %H:%M:%S

# Network specific configurations
ETHEREUM_CHAIN_ID=1
POLYGON_CHAIN_ID=137
BINANCE_CHAIN_ID=56

# API endpoint configurations
API_ENDPOINT_TIMEOUT=30
API_MAX_CONNECTIONS=10

# Cache configuration
CACHE_MAX_SIZE=100000000
CACHE_EVICTION_POLICY=lru

# Performance and scaling
CALCULATION_PARALLEL_PROCESSING=true
CALCULATION_BATCH_SIZE=100

# Fallback configurations
FALLBACK_ENABLED=true
FALLBACK_STRATEGY=cache_then_api

# Network and connection resiliency
CONNECTION_RETRY_COUNT=3
CONNECTION_RETRY_BACKOFF=1.0
CONNECTION_TIMEOUT=30

# Data validation
VALIDATION_STRICT_MODE=false
VALIDATION_SANITIZE_INPUTS=true

# Cache warming
CACHE_WARMUP_ENABLED=true
CACHE_WARMUP_SCHEDULE=*/30 * * * *

# Alerting
ALERTING_ENABLED=false
ALERTING_THRESHOLD=0.1

# Output formatting
OUTPUT_PRECISION=6
OUTPUT_FORMAT=standard

# Network configuration
NETWORK_NAME=mainnet
NETWORK_CHAIN_ID=1

# API configuration
API_VERSION=v1
API_STRICT_TLS=true

# Cache configuration
CACHE_VERSIONING=true
CACHE_COMPRESSION_LEVEL=6

# Data processing
DATA_PROCESSING_ENABLED=true
DATA_PROCESSING_PARALLEL=true

# Monitoring
MONITORING_INTERVAL=60
MONITORING_ENABLED=true

# Performance settings
PERFORMANCE_PROFILING=false
PERFORMANCE_PROFILE_INTERVAL=10

# Cache backend
CACHE_BACKEND_TYPE=memory
CACHE_BACKEND_CONFIG={"host": "localhost", "port": 6379}

# Network settings
NETWORK_CONNECTION_POOL_SIZE=10
NETWORK_TIMEOUT_CONNECT=30
NETWORK_TIMEOUT_READ=30

# API settings
API_RETRY_COUNT=3
API_RETRY_BACKOFF=1.0

# Cache settings
CACHE_TTL_DEFAULT=300
CACHE_TTL_SHORT=60
CACHE_TTL_LONG=3600

# Data settings
DATA_RETENTION_DAYS=30
DATA_BACKUP_ENABLED=true

# Network and API settings
NETWORK_API_CONCURRENCY=5
NETWORK_API_TIMEOUT=30

# Validation settings
VALIDATION_ENABLED=true
VALIDATION_STRICT=false

# Cache settings
CACHE_ENABLED=true
CACHE_TTL=3600

# Output settings
OUTPUT_FORMAT=json
OUTPUT_COMPACT=false

# Performance settings
PERFORMANCE_CACHE=true
PERFORMANCE_LOGGING=false

# Network settings
NETWORK_LATENCY_THRESHOLD=5.0
NETWORK_RETRY_JITTER=0.1

# API settings
API_RATE_LIMIT_PER_SECOND=10
API_CIRCUIT_BREAKER=false

# Cache settings
CACHE_STRATEGY=lru
CACHE_SIZE=1000

# Data settings
DATA_VERSION=1.0
DATA_ENCRYPTION=false

