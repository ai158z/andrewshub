# Staking Reward Calculator - Environment Variables Example File
# This file contains example environment variables for the staking reward calculator CLI application

# Default staking parameters
DEFAULT_PRINCIPAL=1000.0
DEFAULT_APR=5.0
DEFAULT_COMPOUND_FREQUENCY=12
DEFAULT_LOCKUP_PERIOD=12
DEFAULT_LOCKUP_PENALTY=0.0

# Output formatting
OUTPUT_DECIMAL_PLACES=2
OUTPUT_CURRENCY_SYMBOL=USD

# Feature flags
ENABLE_LOCKUP_PENALTY=true
ENABLE_TAX_CALCULATION=false

# Tax calculation settings (if enabled)
TAX_RATE=0.0
WITHHOLDING_TAX_RATE=0.0

# Application settings
APP_NAME=staking-reward-calculator
LOG_LEVEL=INFO

# Display settings
DISPLAY_FORMAT=table
OUTPUT_FORMAT=console

# Performance settings
CACHE_RESULTS=false
MAX_CACHE_SIZE=100

# Validation settings
MIN_PRINCIPAL_AMOUNT=0.01
MAX_PRINCIPAL_AMOUNT=1000000.0
MIN_APR_RATE=0.0
MAX_APR_RATE=100.0

# Default compound frequencies
DAILY_COMPOUND=365
MONTHLY_COMPOUND=12
QUARTERLY_COMPOUND=4
ANNUAL_COMPOUND=1

# File paths (if output to file is needed)
OUTPUT_DIR=./output
LOG_FILE=staking_calculator.log

# Currency and locale settings
CURRENCY_DECIMAL_PLACES=2
THOUSANDS_SEPARATOR=,
DECIMAL_SEPARATOR=.

# Default time period settings (in months)
DEFAULT_TIME_PERIOD=12
MIN_TIME_PERIOD=1
MAX_TIME_PERIOD=120

# Color output settings
ENABLE_COLOR_OUTPUT=true
THEME=dark

# Default validator settings
DEFAULT_VALIDATOR_TYPE=ethereum
DEFAULT_VALIDATOR_NETWORK=mainnet

# API settings (if applicable)
API_TIMEOUT=30
API_RETRIES=3

# Help and documentation settings
SHOW_DETAILED_HELP=true
SHOW_EXAMPLES=true

# Debug settings
DEBUG=false
VERBOSE=false

# Environment
ENVIRONMENT=production
VERSION=1.0.0