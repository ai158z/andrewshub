# Staking Reward Calculator - Environment Variables

# Application Settings
DEBUG=false
LOG_LEVEL=INFO
DATA_DIR=./data
OUTPUT_DIR=./output

# Calculator Settings
DEFAULT_STAKE_AMOUNT=1000
DEFAULT_ANNUAL_RATE=0.08
DEFAULT_PENALTY_RATE=0.02
DEFAULT_LOCKUP_PERCENT=0.10

# Display Settings
CURRENCY_SYMBOL=USD
DECIMAL_PLACES=2

# Test Configuration
TEST_DATA_FILE=test_data.csv
TEST_SCENARIOS_COUNT=100

# Feature Flags
ENABLE_COMPOUNDING=true
ENABLE_PENALTY_CALCULATION=true
ENABLE_DETAILED_LOGS=false

# Output Settings
SAVE_RESULTS_TO_FILE=false
RESULTS_FILE_PATH=./results/staking_results.csv

# Performance Settings
MAX_CONCURRENT_CALCULATIONS=5
CACHE_SIZE=1000

# API/External Service Settings (if applicable)
API_TIMEOUT=30
API_RETRIES=3
API_BASE_URL=https://api.stakingrewards.com

# Security Settings
ENABLE_INPUT_VALIDATION=true
MAX_INPUT_VALUE=1000000.00
MIN_INPUT_VALUE=1.00

# Localization
LOCALE=en_US
TIMEZONE=UTC