# Quantum Sensory Feedback System - Environment Configuration Example

# Server Configuration
DEBUG=false
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
WORKERS=4

# Redis Configuration
REDIS_URL=redis://localhost:6379/0
REDIS_TIMEOUT=5

# RabbitMQ Configuration
RABBITMQ_URL=amqp://guest:guest@localhost:5672//
RABBITMQ_QUEUE_PREFIX=quantum_sensory

# Security Configuration
API_KEY_SECRET=your-super-secret-jwt-key-here
ENCRYPTION_KEY=your-32-byte-encryption-key-here

# Logging Configuration
LOG_LEVEL=INFO
LOG_FORMAT=json

# Quantum Processing Configuration
QISKIT_BACKEND=statevector_simulator
QISKIT_SHOTS=1024
QUANTUM_PRECISION=64

# Service URLs
API_BASE_URL=http://localhost:8000
WEBSOCKET_URL=ws://localhost:8000/ws

# Performance Settings
MAX_CONNECTIONS=100
TIMEOUT=30
MAX_UPLOAD_SIZE=50MB

# Feature Flags
ENABLE_QUANTUM_SIMULATION=true
ENABLE_PATTERN_RECOGNITION=true
ENABLE_ADAPTIVE_FEEDBACK=true

# Cache Settings
CACHE_TTL=300
CACHE_ENABLED=true

# Retry Configuration
MAX_RETRIES=3
RETRY_DELAY=1

# Sensory Input Configuration
SENSORY_INPUT_TIMEOUT=10
SENSORY_DATA_BUFFER_SIZE=1024

# Actuator Configuration
ACTUATOR_RESPONSE_TIMEOUT=5
ACTUATOR_MAX_FORCE=100.0

# System Integration
ORCH_OR_ENABLED=false
ORCH_OR_ENDPOINT=http://localhost:5000/orch-or
QISKIT_PROVIDER_BACKEND=ibmq_qasm_simulator

# Monitoring
HEALTH_CHECK_INTERVAL=30
METRICS_ENABLED=true