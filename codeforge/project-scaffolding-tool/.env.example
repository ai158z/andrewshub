# .env.example
# Environment variables for project-scaffolding-tool CLI

# Default project settings
DEFAULT_PROJECT_TYPE=python
DEFAULT_FRAMEWORK=none
DEFAULT_LICENSE=MIT
DEFAULT_PYTHON_VERSION=3.9

# Template configuration
TEMPLATE_SOURCE=local
TEMPLATE_PATH=./templates

# Output settings
OUTPUT_DIR=./projects
LOG_LEVEL=INFO
VERBOSE=false

# Feature flags
ENABLE_GIT_INIT=true
ENABLE_VENV=true
ENABLE_DEPENDENCY_INSTALL=false

# Scaffolding options
PROJECT_AUTHOR=Your Name
PROJECT_EMAIL=your.email@example.com
PROJECT_LICENSE=MIT
PROJECT_VERSION=0.1.0

# Template-specific variables
PYTHON_DEFAULT_VERSION=3.9
JAVASCRIPT_DEFAULT_PACKAGE_MANAGER=npm
RUST_DEFAULT_EDITION=2021

# CLI behavior
INTERACTIVE_MODE=true
OVERWRITE_EXISTING=false

# Performance settings
MAX_CONCURRENT_OPERATIONS=4
CACHE_TEMPLATES=true

# Security settings
ENABLE_PERMISSIONS_CHECK=true
SECURE_FILE_PERMISSIONS=644
SECURE_DIR_PERMISSIONS=755